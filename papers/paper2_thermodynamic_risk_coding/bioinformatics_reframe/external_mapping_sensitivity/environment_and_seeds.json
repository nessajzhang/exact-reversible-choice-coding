{
  "analysis": "Paper 2 post hoc external KAPA mapping sensitivity",
  "claim_boundary": "post hoc deterministic mapping sensitivity on public external-KAPA measurements; mappings are not biological repeats, do not define a confidence interval and do not replace the analysis-plan-locked primary mapping",
  "command": "$PYTHON analysis_tools/analyze_paper2_external_mapping_sensitivity.py --jobs 12",
  "eligible_sequences": 2053,
  "input_mode": "frozen_derived_mapping_inputs",
  "library_sequences_per_mapping": 2048,
  "mapping_namespaces": 32,
  "packages": {
    "joblib": "1.4.2",
    "numpy": "1.26.4",
    "pandas": "2.2.3"
  },
  "platform": "macOS-13.7.8-x86_64-i386-64bit",
  "python": "3.9.2 (default, Feb 24 2021, 13:26:09) \n[Clang 12.0.0 (clang-1200.0.32.29)]",
  "score_key_contract": {
    "candidate_order": "lexicographically minimize (-quantized_key, choice_index)",
    "decimal_places": 12,
    "input_dtype": "float64",
    "integer_scale": 1000000000000,
    "nonfinite_behavior": "reject",
    "out_of_range_behavior": "reject",
    "output_dtype": "int64",
    "rounding": "IEEE-754 binary64 round-to-nearest, ties-to-even via numpy.rint",
    "signed_int64_max": 9223372036854775807,
    "signed_int64_min": -9223372036854775808,
    "tie_break": "smallest declared choice index"
  },
  "selector_bits": [
    2,
    4
  ],
  "source_models": [
    "GCall",
    "GCfix"
  ]
}
